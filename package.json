{
  "name": "root",
  "version": "4.9.3",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "description": "A standalone components library for Vue.Js & Nuxt.Js",
  "author": "LouisMazel <me@loicmazuel.com>",
  "license": "ISC",
  "homepage": "https://maz-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LouisMazel/maz-ui.git"
  },
  "bugs": {
    "url": "https://github.com/LouisMazel/maz-ui/issues"
  },
  "keywords": [
    "vue",
    "components",
    "vue-component",
    "framework",
    "library",
    "ui"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "make clean",
    "prepare": "npx husky",
    "pre-commit": "lint-staged",
    "commit": "cz",
    "build:all": "nx run-many -t build",
    "build:apps": "nx run-many -t build -p docs nuxt-app vue-app",
    "build:utils": "nx run-many -t build -p @maz-ui/node @maz-ui/utils",
    "build:packages": "nx run-many -t build -p '@maz-ui/*' maz-ui",
    "build:packages:test": "nx run-many -t build -p @maz-ui/translations @maz-ui/icons @maz-ui/node @maz-ui/utils",
    "lint": "cross-env NODE_ENV=production eslint",
    "lint:fix": "cross-env NODE_ENV=production eslint --fix",
    "lint:all": "nx run-many -t lint",
    "lint:fix:all": "nx run-many -t lint:fix",
    "typecheck:all": "nx run-many -t typecheck",
    "test:unit:all": "nx run-many -t test:unit",
    "test:unit:coverage:all": "nx run-many -t test:unit:coverage",
    "healthcheck": "pnpm lint:all && pnpm typecheck:all && pnpm test:unit:coverage:all && pnpm build:packages && nx run docs:build",
    "relizy": "relizy",
    "nx:cache:clear": "nx reset",
    "dev:watch": "nx run-many -t dev",
    "yolo": "yolo"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^2.0.1",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.1",
    "@maz-ui/node": "workspace:*",
    "@nx/js": "^22.6.5",
    "@types/node": "^25.6.0",
    "@types/parse-path": "^7.1.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@yoloship/action": "0.1.0-beta.4",
    "@yoloship/claude-sdk": "0.1.0-beta.4",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "16.4.0",
    "nx": "^22.6.5",
    "postcss": "^8.5.10",
    "postcss-html": "^1.8.1",
    "postcss-nested": "^7.0.2",
    "postcss-url": "^10.1.3",
    "relizy": "1.3.3",
    "stylelint": "^17.8.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "tsx": "^4.21.0",
    "twitter-api-v2": "^1.29.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-svg-loader": "^5.1.1",
    "vitest": "4.1.5",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.7"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,md,yml,json}": [
      "eslint --fix"
    ]
  }
}
