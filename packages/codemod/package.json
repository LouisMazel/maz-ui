{
  "name": "@maz-ui/codemod",
  "type": "module",
  "version": "5.0.0-beta.0",
  "description": "Automated source rewrites for migrating a project from Maz-UI v4 (Tailwind v3) to v5 (Tailwind v4).",
  "author": "Louis Mazel <me@loicmazuel.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LouisMazel/maz-ui.git"
  },
  "bugs": "https://github.com/LouisMazel/maz-ui/issues",
  "keywords": [
    "maz-ui",
    "codemod",
    "migration",
    "tailwindcss",
    "tailwind-v4"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "maz-ui-codemod": "./dist/cli.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "lint": "cross-env NODE_ENV=production eslint .",
    "lint:fix": "pnpm lint --fix"
  },
  "dependencies": {
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@maz-ui/eslint-config": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts,cjs,md,yml,json}": "cross-env NODE_ENV=production eslint --fix"
  }
}
