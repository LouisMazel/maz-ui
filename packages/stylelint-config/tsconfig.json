{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["node", "vitest/globals"],
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "outDir": "dist",
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    "build.config.ts"
  ],
  "exclude": [
